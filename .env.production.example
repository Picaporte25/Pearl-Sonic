# Variables de Entorno para PRODUCCIÓN - Sound-Weaver
# IMPORTANTE: Copia este archivo a .env.production y completa los valores reales
# NUNCA subas este archivo con valores reales a git o repositorios públicos

# ============================================================================
# CONFIGURACIÓN DE AUTENTICACIÓN (CRÍTICO)
# ============================================================================
# JWT_SECRET: Secret key para firmar tokens JWT
# Genera uno seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TU_JWT_SECRET_AQUI_GENERADO_COMO_EL_DE_ABAJO

# Ejemplo de JWT_SECRET seguro (USA ESTE O GENERA OTRO):
# JWT_SECRET=de9b2bedf3aa15e596aadd811754b8a19347b5a87271a57f6f49d46b95686d111ca9f7a3df98508fe6634471a91a65163880def1b996e36e378461737bc1cbd8

# ============================================================================
# CONFIGURACIÓN DE SUPABASE (OBLIGATORIO)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ============================================================================
# CONFIGURACIÓN DE PADDLE (PAGOS - OBLIGATORIO)
# ============================================================================
# Paddle API Key para operaciones del servidor (server-side)
PADDLE_API_KEY=live_your_paddle_api_key_here

# Paddle Webhook Secret (para verificar webhooks)
PADDLE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Paddle Client Token para operaciones del cliente (client-side)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=paddle_client_token_here

# Paddle Environment: 'sandbox' para testing, 'production' para lanzamiento
NEXT_PUBLIC_PADDLE_ENVIRONMENT=production

# ============================================================================
# PRICE IDs DE PADDLE (OBTENER DEL DASHBOARD DE PADDLE)
# ============================================================================
# Estos son los IDs de los productos/precios que creaste en Paddle
NEXT_PUBLIC_PADDLE_PRICE_STARTER=pri_01hj...your_starter_price_id
NEXT_PUBLIC_PADDLE_PRICE_PRO=pri_02k...your_pro_price_id
NEXT_PUBLIC_PADDLE_PRICE_CREATOR=pri_03l...your_creator_price_id
NEXT_PUBLIC_PADDLE_PRICE_STUDIO=pri_04m...your_studio_price_id

# ============================================================================
# CONFIGURACIÓN DE FAL.AI (OPCIONAL)
# ============================================================================
FAL_API_KEY=your_fal_api_key_here

# ============================================================================
# CONFIGURACIÓN ADICIONAL (OPCIONAL)
# ============================================================================
# Rate Limiting con Redis (recomendado para producción)
# REDIS_URL=redis://username:password@redis-host:6379

# Upstash Redis (alternativa recomendada para Vercel)
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ============================================================================
# INSTRUCCIONES DE CONFIGURACIÓN:
# ============================================================================
# 1. Crea tu cuenta en Supabase y obtén las credenciales
# 2. Crea tu cuenta en Paddle y obtén las credenciales
# 3. Crea los productos/precios en Paddle y obtén los Price IDs
# 4. Configura el webhook de Paddle en tu backend
# 5. Ejecuta supabase-setup-safe.sql en tu proyecto de Supabase
# 6. Genera un JWT_SECRET seguro y configúralo aquí
# 7. Copia este archivo a .env.production y completa todos los valores
# 8. Haz build: npm run build
# 9. Deploy a producción

# ============================================================================
# IMPORTANTE:
# ============================================================================
# - NUNCA uses los valores de ejemplo en producción
# - NUNCA compartas tus credenciales de producción
# - NUNCA subas archivos .env con valores reales a git
# - GUARDA este archivo con valores reales de forma segura
# - Actualiza regularmente tus secrets y claves